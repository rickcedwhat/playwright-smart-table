{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "symlinkDirectories": []
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.worktreePath' | { read -r p; cd \"$p\" && source ~/.zshrc && pnpm install --frozen-lockfile; }",
            "statusMessage": "Installing pnpm dependencies in new worktree..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/fallow-gate.sh"
          }
        ]
      }
    ]
  }
}
