# GitHub Models API Key (Recommended)
# Create a Personal Access Token (classic) with no scopes at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OR OpenAI API Key
# OPENAI_API_KEY=your_openai_key_here

# Model Selection (defaults to gpt-4o for GitHub, gpt-4o-mini for OpenAI)
# LLM_MODEL=gpt-4o
