{
  "name": "@rickcedwhat/playwright-smart-table",
  "version": "6.7.7",
  "description": "Smart, column-aware table interactions for Playwright",
  "author": "Cedrick Catalan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rickcedwhat/playwright-smart-table.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate-types": "node scripts/embed-types.mjs",
    "generate-config-types": "node scripts/embed-config-types.mjs",
    "generate-docs": "node scripts/generate-readme.mjs",
    "generate-all-api-docs": "node scripts/generate-all-api-docs.mjs",
    "update-all-api-signatures": "node scripts/update-all-api-signatures.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "build": "npm run generate-types && npm run generate-config-types && npm run generate-docs && npm run generate-all-api-docs && npm run update-all-api-signatures && tsc",
    "prepublishOnly": "npm run build",
    "clean-port": "lsof -ti:3000 | xargs kill -9 || true",
    "pretest": "npm run clean-port",
    "posttest": "npm run clean-port",
    "test": "npm run test:unit && npx playwright test",
    "test:unit": "vitest run --coverage --reporter=verbose --reporter=html",
    "test:unit:ui": "vitest --ui",
    "test:mutate": "npx stryker run",
    "pretest:e2e": "npm run clean-port",
    "posttest:e2e": "npm run clean-port",
    "test:e2e": "npx playwright test",
    "dev:playground": "cd playground && npm run dev",
    "dev:mui": "cd tests/apps/mui-datagrid && npm run dev",
    "prepare": "husky install"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "default": "./dist/presets/index.js"
    },
    "./presets/mui": {
      "types": "./dist/presets/mui.d.ts",
      "default": "./dist/presets/mui.js"
    }
  },
  "keywords": [
    "playwright",
    "testing",
    "table",
    "automation"
  ],
  "peerDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  }
}