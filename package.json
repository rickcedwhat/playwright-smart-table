{
  "name": "@rickcedwhat/playwright-smart-table",
  "version": "6.11.0",
  "description": "Smart, column-aware table interactions for Playwright",
  "author": "Cedrick Catalan",
  "license": "MIT",
  "homepage": "https://rickcedwhat.github.io/playwright-smart-table/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickcedwhat/playwright-smart-table.git"
  },
  "bugs": {
    "url": "https://github.com/rickcedwhat/playwright-smart-table/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate-types": "node scripts/embed-types.mjs",
    "generate-config-types": "node scripts/embed-config-types.mjs",
    "generate-docs": "node scripts/generate-readme.mjs",
    "generate-all-api-docs": "node scripts/generate-all-api-docs.mjs",
    "update-all-api-signatures": "node scripts/update-all-api-signatures.mjs",
    "docs:dev": "vitepress dev docs --host",
    "docs:build": "node scripts/docs-build-prod.mjs",
    "docs:build:all": "vitepress build docs",
    "docs:verify-links": "node scripts/verify-vitepress-links.mjs",
    "embed-version": "node scripts/embed-version.mjs",
    "build": "pnpm run embed-version && pnpm run generate-types && pnpm run generate-config-types && pnpm run generate-docs && pnpm run generate-all-api-docs && pnpm run update-all-api-signatures && tsc",
    "prepublishOnly": "pnpm run build",
    "clean-port": "lsof -ti:3000 | xargs kill -9 || true",
    "pretest": "pnpm run clean-port",
    "posttest": "pnpm run clean-port",
    "test": "pnpm run test:unit && pnpm exec playwright test",
    "test:unit": "vitest run --coverage --reporter=verbose --reporter=html",
    "test:unit:ui": "vitest --ui",
    "test:mutate": "pnpm exec stryker run",
    "pretest:e2e": "pnpm run clean-port",
    "posttest:e2e": "pnpm run clean-port",
    "test:e2e": "pnpm exec playwright test",
    "test:playground": "pnpm exec playwright test --config tests-external/playground/playwright.config.ts 2>&1 | tee \"tests-external/playground/logs/run-$(date +%Y%m%d-%H%M%S).log\"",
    "dev:playground": "cd playground && npm run dev",
    "dev:mui": "cd tests/apps/mui-datagrid && npm run dev",
    "prepare": "husky"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "default": "./dist/presets/index.js"
    },
    "./presets/mui": {
      "types": "./dist/presets/mui.d.ts",
      "default": "./dist/presets/mui.js"
    }
  },
  "keywords": [
    "playwright",
    "testing",
    "table",
    "automation",
    "locators",
    "e2e",
    "qa",
    "typescript",
    "datagrid",
    "smart-table",
    "ag-grid",
    "mui"
  ],
  "peerDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^20.8.3",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@scarf/scarf": "^1.4.0"
  },
  "packageManager": "pnpm@10.33.2"
}
